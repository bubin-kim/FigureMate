# LLM Provider Layer (app/core/llm/) — 기본 mock: 개발 중 API 비용 0
# LLM_PROVIDER: mock | ollama | anthropic | openai(슬롯 예약)
# EMBEDDING_PROVIDER: mock | ollama  (Anthropic은 임베딩 API가 없어 별도 설정)
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Ollama (LLM_PROVIDER=ollama 또는 EMBEDDING_PROVIDER=ollama 사용 시, 로컬·무비용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b            # M3 텍스트 매칭 검증용 (텍스트 전용)
OLLAMA_VISION_MODEL=qwen2.5vl:7b  # M4 explainer용 (Vision 필수 — 텍스트 모델과 분리)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Claude API (LLM_PROVIDER=anthropic 사용 시에만 필요 — 유료)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Database
DATABASE_URL=postgresql+psycopg://figuremate:figuremate@localhost:5432/figuremate

# Storage (M1 단계: 로컬 경로로 시작, 이후 S3 등으로 교체 가능)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# S3 호환 스토리지로 전환 시 (M2 이후):
# STORAGE_BACKEND=s3
# STORAGE_BUCKET=
# STORAGE_ENDPOINT_URL=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
